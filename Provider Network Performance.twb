      <aliases enabled='yes' />
      <column caption='Avg Payment per Service' datatype='real' name='[Calculation_863565237395603466]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Tot_Mdcr_Pymt_Amt]) / SUM([Tot_Srvcs])' />
      </column>
      <column caption='Charge to Payment Ratio' datatype='real' name='[Calculation_863565237395656715]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Tot_Sbmtd_Chrg]) / SUM([Tot_Mdcr_Pymt_Amt])' />
