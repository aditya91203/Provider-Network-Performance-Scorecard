    <worksheet name='Provider Drill'>
      <table>
        <view>
          <datasources>
            <datasource caption='Unplanned_Hospital_Visits-Hospital+' name='federated.1bix3bw1i9icar1gisu2j16c6kul' />
          </datasources>
          <datasource-dependencies datasource='federated.1bix3bw1i9icar1gisu2j16c6kul'>
            <column caption='Quality Tier' datatype='string' name='[Calculation_863565237373964288]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Visit_vs_National] = &quot;Better Than the National Rate&quot; &#13;&#10;   OR [Visit_vs_National] = &quot;Better than expected&quot;&#13;&#10;   OR [Visit_vs_National] = &quot;Fewer Days Than Average per 100 Discharges&quot;&#13;&#10;THEN &quot;High&quot;&#13;&#10;&#13;&#10;ELSEIF [Visit_vs_National] = &quot;Worse Than the National Rate&quot; &#13;&#10;   OR [Visit_vs_National] = &quot;Worse than expected&quot;&#13;&#10;   OR [Visit_vs_National] = &quot;More Days Than Average per 100 Discharges&quot;&#13;&#10;THEN &quot;At Risk&quot;&#13;&#10;&#13;&#10;ELSEIF [Visit_vs_National] = &quot;No Different Than the National Rate&quot;&#13;&#10;   OR [Visit_vs_National] = &quot;No Different than expected&quot;&#13;&#10;   OR [Visit_vs_National] = &quot;Average Days per 100 Discharges&quot;&#13;&#10;THEN &quot;Average&quot;&#13;&#10;&#13;&#10;ELSE &quot;Insufficient Data&quot;&#13;&#10;END' />
            </column>
            <column aggregation='CountD' datatype='real' name='[Complication_Score]' role='dimension' type='ordinal' />
            <column datatype='string' name='[Facility Name]' role='dimension' type='nominal' />
            <column datatype='string' name='[State]' role='dimension' semantic-role='[State].[Name]' type='nominal' />
            <column caption='Visit Measure Name' datatype='string' name='[Visit_Measure Name]' role='dimension' type='nominal' />
            <column caption='Visit Score' datatype='real' name='[Visit_Score]' role='measure' type='quantitative' />
            <column caption='Visit vs National' datatype='string' name='[Visit_vs_National]' role='dimension' type='nominal' />
            <column-instance column='[Facility Name]' derivation='None' name='[none:Facility Name:nk]' pivot='key' type='nominal' />
            <column-instance column='[State]' derivation='None' name='[none:State:nk]' pivot='key' type='nominal' />
            <column-instance column='[Visit_Measure Name]' derivation='None' name='[none:Visit_Measure Name:nk]' pivot='key' type='nominal' />
            <column-instance column='[Visit_Score]' derivation='None' name='[none:Visit_Score:ok]' pivot='key' type='ordinal' />
            <column-instance column='[Visit_vs_National]' derivation='None' name='[none:Visit_vs_National:nk]' pivot='key' type='nominal' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.1bix3bw1i9icar1gisu2j16c6kul].[Action (Quality Tier,Complication_Score,Facility Name,Visit Score)]'>
            <groupfilter function='crossjoin' user:ui-action-filter='[Action3_B2154E8CE960415C99388CE88A37052E]' user:ui-domain='database' user:ui-enumeration='inclusive' user:ui-marker='enumerate'>
              <groupfilter function='member' level='[Calculation_863565237373964288]' member='&quot;High&quot;' />
              <groupfilter function='crossjoin'>
                <groupfilter function='member' level='[Complication_Score]' member='0.11' />
                <groupfilter function='crossjoin'>
                  <groupfilter function='member' level='[Facility Name]' member='&quot;BILLINGS CLINIC&quot;' />
                  <groupfilter function='member' level='[none:Visit_Score:ok]' member='-33.399999999999999' />
                </groupfilter>
              </groupfilter>
            </groupfilter>
