      <aliases enabled='yes' />
      <column caption='Quality Tier' datatype='string' name='[Calculation_863565237373964288]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Visit_vs_National] = &quot;Better Than the National Rate&quot; &#13;&#10;   OR [Visit_vs_National] = &quot;Better than expected&quot;&#13;&#10;   OR [Visit_vs_National] = &quot;Fewer Days Than Average per 100 Discharges&quot;&#13;&#10;THEN &quot;High&quot;&#13;&#10;&#13;&#10;ELSEIF [Visit_vs_National] = &quot;Worse Than the National Rate&quot; &#13;&#10;   OR [Visit_vs_National] = &quot;Worse than expected&quot;&#13;&#10;   OR [Visit_vs_National] = &quot;More Days Than Average per 100 Discharges&quot;&#13;&#10;THEN &quot;At Risk&quot;&#13;&#10;&#13;&#10;ELSEIF [Visit_vs_National] = &quot;No Different Than the National Rate&quot;&#13;&#10;   OR [Visit_vs_National] = &quot;No Different than expected&quot;&#13;&#10;   OR [Visit_vs_National] = &quot;Average Days per 100 Discharges&quot;&#13;&#10;THEN &quot;Average&quot;&#13;&#10;&#13;&#10;ELSE &quot;Insufficient Data&quot;&#13;&#10;END' />
      </column>
      <column caption='Complication Tier' datatype='string' name='[Calculation_863565237377511427]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Complication_vs_National] = &quot;Better than the National Rate&quot; &#13;&#10;THEN &quot;Low Risk&quot;&#13;&#10;ELSEIF [Complication_vs_National] = &quot;Worse than the National Rate&quot; &#13;&#10;THEN &quot;High Risk&quot;&#13;&#10;ELSE &quot;Average&quot;&#13;&#10;END' />
      </column>
