        <calculation class='tableau' formula='IF [Calculation_863565237395603466] &gt; 200 THEN &quot;High Cost&quot;&#13;&#10;ELSEIF [Calculation_863565237395603466] &gt; 100 THEN &quot;Moderate Cost&quot;&#13;&#10;ELSE &quot;Low Cost&quot;&#13;&#10;END' />
